run = "npm run dev"
entrypoint = "src/app/page.tsx"

[nix]
channel = "stable-24_05"

[env]
NEXT_TELEMETRY_DISABLED = "1"

[deployment]
run = ["sh", "-c", "PORT=3000 node .next/standalone/server.js"]
build = ["sh", "-c", "npm install && npm run build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/"]

[[ports]]
localPort = 3000
externalPort = 80
